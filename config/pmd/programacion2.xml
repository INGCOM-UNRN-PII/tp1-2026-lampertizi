<?xml version="1.0"?>
<ruleset name="Programación 2 - UNRN Sede Andina"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 http://pmd.sourceforge.net/ruleset_2_0_0.xsd">
    <description>
        Configuración PMD para Programación 2 - Ingeniería en Computación [UNRN-Andina].
        
        Esta configuración implementa las reglas definidas en apuntes_2025.md
        
        Categorías de reglas (numeración hexadecimal):
        - 0x0xxx: Nomenclatura y formato general
        - 0x1xxx: Documentación y comentarios  
        - 0x2xxx: Diseño de clases y POO
        - 0x3xxx: Manejo de excepciones
        - 0x4xxx: Testing
        - 0x5xxx: Estructuras de control
        - 0x6xxx: Restricciones de programación funcional
        - 0xExxx: Errores comunes (Error-Prone)
        
        Ver apuntes_2025.md para descripción completa de cada regla.
    </description>

    <!-- ========================================= -->
    <!-- Serie 0x2 - Diseño de Clases y POO       -->
    <!-- ========================================= -->
    
    <rule ref="category/java/bestpractices.xml" >
        <!-- Por el momento, las aplicaciones son simples y por CLI -->
        <exclude name="SystemPrintln" />
    </rule>
    
    <!-- Excluir AvoidPrintStackTrace en métodos main -->
    <rule ref="category/java/bestpractices.xml/AvoidPrintStackTrace">
        <properties>
            <property name="violationSuppressXPath" value="//MethodDeclaration[@Name='main']" />
        </properties>
    </rule>
    
    <!-- 0x5003 - No usar parámetros como variables si cambia significado -->
    <rule ref="category/java/bestpractices.xml/AvoidReassigningParameters">
        <properties>
            <property name="violationSuppressXPath" value="//ConstructorDeclaration"/>
        </properties>
    </rule>

    <!-- ========================================= -->
    <!-- Serie 0x0 - Nomenclatura y Formato       -->
    <!-- Serie 0x2 - Diseño de Clases             -->
    <!-- ========================================= -->
    
    <rule ref="category/java/codestyle.xml">
        <!-- Variables finales no son necesarias para aprendizaje inicial -->
        <exclude name="MethodArgumentCouldBeFinal" />
        <exclude name="LocalVariableCouldBeFinal" />
        <!-- No siempre es necesario un constructor explícito -->
        <exclude name="AtLeastOneConstructor" />
    </rule>
    
    <!-- 0x4000 - Test debe tener nombre de clase + Test al final -->
    <rule ref="category/java/codestyle.xml/ClassNamingConventions">
        <properties>
            <property name="utilityClassPattern" value="[A-Z][a-zA-Z0-9]*" />
            <property name="testClassPattern" value="[A-Z][a-zA-Z0-9]*Test" />
        </properties>
    </rule>
    
    <!-- 0x0006 - Identificadores descriptivos (mínimo 2 caracteres) -->
    <rule ref="category/java/codestyle.xml/ShortMethodName">
        <properties>
            <property name="minimum" value="2" />
        </properties>
    </rule>
    
    <!-- 0x0007 - Identificadores booleanos con prefijos interrogativos -->
    <rule ref="category/java/codestyle.xml/LinguisticNaming" >
        <properties>
            <property name="violationSuppressXPath" value="//ClassOrInterfaceBodyDeclaration/Annotation/MarkerAnnotation//Name[@Image='Test']" />
        </properties>
    </rule>

    <!-- ========================================= -->
    <!-- Serie 0x2 - Diseño de Clases (cont.)     -->
    <!-- Serie 0x5 - Complejidad                  -->
    <!-- ========================================= -->
    
    <rule ref="category/java/design.xml">
        <!-- Clases con métodos estáticos son de soporte, permitido inicialmente -->
        <exclude name="UseUtilityClass" />
        <!-- Law of Demeter conflicta con algunas prácticas modernas -->
        <exclude name="LawOfDemeter" />
        <!-- Requiere configuración explícita, excluido por ahora -->
        <exclude name="LoosePackageCoupling" />
        <!-- Se reconfigura abajo -->
        <exclude name="CyclomaticComplexity" />
    </rule>
    
    <!-- 0x5005 - Evitar anidamiento profundo (complejidad ciclomática) -->
    <rule ref="category/java/design.xml/CyclomaticComplexity">
        <properties>
            <property name="methodReportLevel" value="10"/>
            <!-- Excluir métodos main (puntos de entrada) -->
            <property name="violationSuppressXPath" value="//MethodDeclaration[@Name='main']" />
        </properties>
    </rule>

    <!-- ========================================= -->
    <!-- Serie 0x1 - Documentación                -->
    <!-- Serie 0x3 - Excepciones                  -->
    <!-- ========================================= -->
    
    <!-- 0x1000, 0x1001 - Documentación Javadoc requerida -->
    <!-- 0x1002, 0x1003 - Documentar excepciones con @throws -->
    <rule ref="category/java/documentation.xml"/>
    
    <rule ref="category/java/documentation.xml/CommentRequired">
        <properties>
            <!-- Los atributos no siempre requieren documentación -->
            <property name="fieldCommentRequirement" value="Ignored" />
            <property name="publicMethodCommentRequirement" value="Required" />
            <property name="protectedMethodCommentRequirement" value="Required" />
            <property name="enumCommentRequirement" value="Required" />
            <!-- Excluir métodos main (puntos de entrada) -->
            <property name="violationSuppressXPath" value="//MethodDeclaration[@Name='main']" />
        </properties>
    </rule>
    
    <rule ref="category/java/documentation.xml/CommentSize">
        <properties>
            <!-- Permitir comentarios más extensos con múltiples tags -->
            <property name="maxLines" value="30" />
            <property name="maxLineLength" value="150" />
        </properties>
    </rule>

    <!-- ========================================= -->
    <!-- Multithreading (no usado en el curso)    -->
    <!-- ========================================= -->

    <rule ref="category/java/multithreading.xml"/>

    <rule ref="category/java/performance.xml"/>

    <rule ref="category/java/security.xml"/>

    <!-- ========================================= -->
    <!-- Serie 0x3 - Manejo de Excepciones        -->
    <!-- Serie 0xE - Errores Comunes              -->
    <!-- ========================================= -->
    
    <rule ref="category/java/errorprone.xml">
        <exclude name="EmptyCatchBlock" />
    </rule>
    
    <!-- Excluir CloseResource en métodos main (scanner con System.in) -->
    <rule ref="category/java/errorprone.xml/CloseResource">
        <properties>
            <property name="violationSuppressXPath" value="//MethodDeclaration[@Name='main']" />
        </properties>
    </rule>
    
    <!-- 0x300B - Silenciar excepciones no es gestionarlas -->
    <rule ref="category/java/errorprone.xml/EmptyCatchBlock">
        <properties>
            <property name="allowCommentedBlocks" value="false"/>
        </properties>
    </rule>
    
    <!-- 0x300D - Atajar para hacer print no es gestionar -->
    <rule name="AvoidPrintStackTraceInCatch"
          language="java"
          message="[0x300D] Atajar para hacer print (printStackTrace, System.out) no gestiona la excepción"
          class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
        <description>
            Detecta printStackTrace() y System.out/err dentro de bloques catch (0x300D)
        </description>
        <priority>3</priority>
        <properties>
            <property name="xpath">
                <value>
<![CDATA[
//CatchStatement//PrimaryExpression[ends-with(PrimaryPrefix/Name/@Image, '.printStackTrace')]
| //CatchStatement//PrimaryExpression[PrimaryPrefix/Name/@Image='System.out' or PrimaryPrefix/Name/@Image='System.err']
]]>
                </value>
            </property>
        </properties>
    </rule>

    <!-- 0x3008 - No declarar RuntimeException en throws -->
    <rule ref="category/java/design.xml/SignatureDeclareThrowsException" >
        <properties>
            <property name="IgnoreJUnitCompletely" value="true" />
        </properties>
    </rule>

    <!-- ========================================= -->
    <!-- Serie 0x6 - Programación Funcional       -->
    <!-- ========================================= -->
    
    <!-- 0x6000 - No usar expresiones lambda -->
    <rule name="AvoidLambdaExpressions"
          language="java"
          message="[0x6000] No usar lambdas (->). Usar bucles for/while tradicionales"
          class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
        <description>
            Detecta expresiones lambda. Regla 0x6000 de apuntes_2025.md
        </description>
        <priority>3</priority>
        <properties>
            <property name="xpath">
                <value>
<![CDATA[
//LambdaExpression
]]>
                </value>
            </property>
        </properties>
    </rule>

    <!-- 0x6001 - No usar referencias a métodos -->
    <rule name="AvoidMethodReferences"
          language="java"
          message="[0x6001] No usar method references (::). Usar bucles for/while tradicionales"
          class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
        <description>
            Detecta referencias a métodos (::). Regla 0x6001 de apuntes_2025.md
        </description>
        <priority>3</priority>
        <properties>
            <property name="xpath">
                <value>
<![CDATA[
//MethodReference
]]>
                </value>
            </property>
        </properties>
    </rule>

    <!-- 0x6002 - No usar Stream API -->
    <rule name="AvoidStreamAPI"
          language="java"
          message="[0x6002] No usar Stream API. Usar bucles for/while tradicionales"
          class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
        <description>
            Detecta uso de Stream API (stream(), parallelStream()). Regla 0x6002 de apuntes_2025.md
        </description>
        <priority>3</priority>
        <properties>
            <property name="xpath">
                <value>
<![CDATA[
//PrimaryExpression/PrimarySuffix/Arguments[count(*) = 0]/../../PrimaryPrefix/Name[matches(@Image, '.*\.(stream|parallelStream)$')]
| //MethodInvocation[@MethodName='stream' or @MethodName='parallelStream']
]]>
                </value>
            </property>
        </properties>
    </rule>

    <!-- 0x6004 - No usar Optional -->
    <rule name="AvoidOptionalClass"
          language="java"
          message="[0x6004] No usar Optional. Retornar null documentado o lanzar excepción"
          class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
        <description>
            Detecta uso de la clase Optional. Regla 0x6004 de apuntes_2025.md
        </description>
        <priority>3</priority>
        <properties>
            <property name="xpath">
                <value>
<![CDATA[
//ClassOrInterfaceType[@Image='Optional' or contains(@Image, '.Optional')]
| //Name[matches(@Image, '^Optional$') or matches(@Image, '.*\.Optional$')]
]]>
                </value>
            </property>
        </properties>
    </rule>

    <!-- 0xE004 - hashCode debe usar la librería -->
    <rule name="HashCodeShouldUseLibrary"
          language="java"
          message="[0xE004] La implementación de hashCode debe usar Objects.hash() o Arrays.hashCode()"
          class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
        <description>
            La implementación de hashCode debe emplear Objects o Arrays de la librería
        </description>
        <priority>3</priority>
        <properties>
            <property name="xpath">
                <value>
<![CDATA[
//MethodDeclaration[@Name='hashCode']
  [not(descendant::PrimaryPrefix/Name[starts-with(@Image, 'Objects.hash') or starts-with(@Image, 'Arrays.hashCode')])]
  [count(Block/BlockStatement) > 0]
]]>
                </value>
            </property>
        </properties>
    </rule>

    <!-- 0xE005 - equals debe usar pattern matching para cast -->
    <rule name="EqualsWithoutPatternMatching"
          language="java"
          message="[0xE005] La implementación de equals debe usar Pattern Matching para el cast seguro"
          class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
        <description>
            equals debe usar instanceof con pattern matching en lugar de cast explícito
        </description>
        <priority>3</priority>
        <properties>
            <property name="xpath">
                <value>
<![CDATA[
//MethodDeclaration[@Name='equals']//CastExpression
]]>
                </value>
            </property>
        </properties>
    </rule>

    <!-- 0x0031 - Getters/Setters no pueden usarse para lógica -->
    <rule name="NoBusinessLogicInGettersSetters"
          language="java"
          message="[0x0031] Los métodos get/set no pueden usarse para la lógica del problema"
          class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
        <description>
            Getters y setters no deben contener lógica de negocio compleja
        </description>
        <priority>3</priority>
        <properties>
            <property name="xpath">
                <value>
<![CDATA[
//MethodDeclaration[starts-with(@Name, 'get') or starts-with(@Name, 'set') or starts-with(@Name, 'is')]
  [count(Block/BlockStatement) > 2]
]]>
                </value>
            </property>
        </properties>
    </rule>

    <!-- 0xE003 - No concatenar String en bucles -->
    <rule name="AvoidStringConcatenationInLoops"
          language="java"
          message="[0xE003] No concatenar String en un lazo, usá StringBuilder"
          class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
        <description>
            No concatenar strings dentro de bucles, usar StringBuilder
        </description>
        <priority>3</priority>
        <properties>
            <property name="xpath">
                <value>
<![CDATA[
//WhileStatement//AdditiveExpression[@Operator='+'][PrimaryExpression/PrimaryPrefix/Literal[@StringLiteral='true']]
| //ForStatement//AdditiveExpression[@Operator='+'][PrimaryExpression/PrimaryPrefix/Literal[@StringLiteral='true']]
| //DoStatement//AdditiveExpression[@Operator='+'][PrimaryExpression/PrimaryPrefix/Literal[@StringLiteral='true']]
]]>
                </value>
            </property>
        </properties>
    </rule>

    <!-- 0xE00B y 0xE008 - Excepciones específicas para null vs vacío -->
    <rule name="DifferentExceptionsForNullAndEmpty"
          language="java"
          message="[0xE00B/0xE008] Usar excepciones diferentes para 'null' y 'vacío' - son situaciones distintas"
          class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
        <description>
            null y colecciones vacías son situaciones diferentes que requieren excepciones distintas
        </description>
        <priority>3</priority>
        <properties>
            <property name="xpath">
                <value>
<![CDATA[
//IfStatement[Expression//EqualityExpression and Expression//PrimaryExpression[ends-with(PrimarySuffix/@Image, 'length') or ends-with(PrimarySuffix/@Image, 'size')]]
  [Statement//ThrowStatement]
  [not(following-sibling::IfStatement//ThrowStatement)]
]]>
                </value>
            </property>
        </properties>
    </rule>

    <!-- 0xF000 y 0xE002 - No declarar throws de excepciones no controladas -->
    <rule name="NoThrowsDeclarationForRuntimeException"
          language="java"
          message="[0xF000/0xE002] No declarar 'throws' para excepciones no controladas (RuntimeException y subclases)"
          class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
        <description>
            No es correcto declarar el lanzamiento de excepciones no controladas
        </description>
        <priority>3</priority>
        <properties>
            <property name="xpath">
                <value>
<![CDATA[
//MethodDeclaration/NameList/Name[
  @Image='RuntimeException' or 
  @Image='IllegalArgumentException' or 
  @Image='IllegalStateException' or 
  @Image='NullPointerException' or
  @Image='IndexOutOfBoundsException' or
  @Image='UnsupportedOperationException'
]
]]>
                </value>
            </property>
        </properties>
    </rule>
    </ruleset>